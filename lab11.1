# Use AI to implement a priority queue using Python’s heapq module.Expected Output:• Implementation with enqueue (priority), dequeue (highest priority),and display methods.
import heapq

class PriorityQueue:
    def __init__(self):
        self.queue = []

    def enqueue(self, priority, item):
        heapq.heappush(self.queue, (priority, item))

    def dequeue(self):
        if not self.queue:
            raise IndexError("dequeue from an empty priority queue")
        return heapq.heappop(self.queue)[1]

    def display(self):
        for priority, item in self.queue:
            print(f"Priority: {priority}, Item: {item}")
if __name__ == "__main__":
